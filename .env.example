# Environment for the docker-compose.yaml hub service.
# Copy to `.env` and fill in generated values. `.env` is gitignored —
# never commit real secrets.

# Required. Bearer token every hub client must present.
# Generate: openssl rand -hex 24
CCQA_HUB_TOKEN=

# Required in practice. 32-byte key as 64 hex chars, used to encrypt stored sessions/variables at rest. 
# Without it the hub starts, but storing a session/variable returns 503.
# Generate: openssl rand -hex 32
CCQA_HUB_ENCRYPTION_KEY=

# Optional. Only hub-side triage-learning jobs call Claude; leave unset if you don't use learning.
# ANTHROPIC_API_KEY=
